class Solution {
public:
    int countBits(int n) {
        return __builtin_popcount(n);   // counts number of 1 bits
    }
    
    vector<int> sortByBits(vector<int>& arr) {
        sort(arr.begin(), arr.end(), [&](int a, int b) {
            if (countBits(a) == countBits(b))
                return a < b;                  // normal ascending
            return countBits(a) < countBits(b); // sort by bit count
        });
        
        return arr;
    }
};
