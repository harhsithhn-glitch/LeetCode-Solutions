class Solution {
public:
    bool hasAllCodes(string s, int k) {
        int total = 1 << k;   // 2^k
        
        if (s.length() < total + k - 1)
            return false;

        unordered_set<string> seen;

        for (int i = 0; i <= s.length() - k; i++) {
            seen.insert(s.substr(i, k));
            if (seen.size() == total)
                return true;
        }

        return false;
    }
};
